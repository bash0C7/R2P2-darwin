# Fetched upstream picoruby/picoruby (rake setup) — never committed
/vendor/picoruby/

# Host build output (rake build / build:ble → MRUBY_BUILD_DIR)
/build/
/build-ble/

# bundler / local scratch
/.bundle/
/tmp/

# Claude Code local-only settings (permission grants etc.)
.claude/settings.local.json

# process docs (spec / handoff / plan / notes) — not committed
docs/superpowers/
/HANDOFF*.md
/SPEC*.md
/PLAN*.md
/NOTES*.md

# Swift build artifacts (regenerated locally) — for future Mac-native capability gems
mrbgems/**/ext/.build/
mrbgems/**/ext/*-Swift.h
